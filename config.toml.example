# ByeByeDPI Configuration

[api]
port = 11337
api_key = ""
enabled = true

[windivert]
filter = "ip && (tcp.DstPort == 443 or tcp.SrcPort == 443 or udp.DstPort == 53 or udp.DstPort == 443)"
queue_length = 8192
queue_time = 2000

[dns]
doh_url = "https://cloudflare-dns.com/dns-query"
dot_addr = "1.1.1.1:853"
cache_ttl = 300

[split_tunnel]
mode = "blacklistonly"

[desync]
fake_sni = "www.google.com"
split_size = 1
split_count = 3
fake_ttl_offset = 1

[probe]
enabled = true
auto_probe_domains = ["youtube.com", "telegram.org", "rutracker.org"]
auto_probe_interval = 300  # seconds
dns_udp_servers = ["8.8.8.8", "1.1.1.1", "9.9.9.9"]
dns_doh_urls = ["https://cloudflare-dns.com/dns-query"]
tcp_connect_timeout_ms = 3000
tls_connect_timeout_ms = 5000
http_read_timeout_ms = 8000
tcp16_enabled = false
accumulation_enabled = true
promote_threshold = 50
hot_ttl_seconds = 86400

[proxy]
enabled = true
# Small inline list override
proxy_domains = []
# External file list (one domain per line, supports hot-reload on modify)
proxy_domains_file = "blocked_domains.txt"
# Detect geoblocked sites dynamically via background probe
auto_probe = true
max_connections = 1000
idle_timeout_secs = 300
